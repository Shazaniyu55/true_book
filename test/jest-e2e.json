{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
      "moduleNameMapper": {
      "^@modules/(.*)$": "<rootDir>/modules/$1",
      "^@adapters/(.*)$": "<rootDir>/adapters/$1",
      "^@broker/(.*)$": "<rootDir>/broker/$1",
      "^@shared/(.*)$": "<rootDir>/shared/$1",
      "^@config/(.*)$": "<rootDir>/configs/$1",
      "^src/(.*)$": "<rootDir>/$1"
    }
}
