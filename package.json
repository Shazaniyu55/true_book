{
  "name": "nest-js-boiler-plate",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node  dist/main",
    "preStart": "npm run migration:run",
    "typeorm": "ts-node ./node_modules/typeorm/cli",
    "migration:show": "npm run typeorm migration:show -- -d ./src/configs/typeorm.config.ts",
    "migration:run": "npm run typeorm migration:run -- -d ./src/configs/typeorm.config.ts",
    "migration:generate": "npm run typeorm -- -d ./src/configs/typeorm.config.ts migration:generate ./src/migrations/$npm_config_name",
    "migration:create": "npm run typeorm -- migration:create ./src/migrations/$npm_config_name",
    "migration:revert": "npm run typeorm -- -d ./src/configs/typeorm.config.ts migration:revert",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --testRegex='\\.e2e-spec\\.ts$'"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1052.0",
    "@nestjs/cli": "^10.0.0",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.0.0",
    "@nestjs/event-emitter": "^2.1.1",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/mapped-types": "^2.0.4",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.1",
    "@nestjs/platform-socket.io": "^10.4.22",
    "@nestjs/schedule": "^6.0.1",
    "@nestjs/swagger": "^7.4.0",
    "@nestjs/throttler": "^6.3.0",
    "@nestjs/typeorm": "^10.0.2",
    "@nestjs/websockets": "^10.4.22",
    "accesscontrol": "^2.2.1",
    "axios": "^1.7.9",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cloudinary": "^2.10.0",
    "cookie-parser": "^1.4.7",
    "crypto": "^1.0.1",
    "crypto-random-string": "^3.3.1",
    "date-fns": "^3.6.0",
    "dotenv": "^16.4.7",
    "expo-server-sdk": "^5.0.0",
    "ioredis": "^5.10.1",
    "joi": "^17.13.3",
    "libphonenumber-js": "^1.12.9",
    "multer": "^2.1.1",
    "nanoid": "^3.3.6",
    "nest-access-control": "^3.2.0",
    "nestjs-cls": "^4.5.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.12.0",
    "qrcode": "^1.5.4",
    "reflect-metadata": "^0.2.0",
    "resend": "^6.12.3",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.3",
    "streamifier": "^0.1.1",
    "typeorm": "^0.3.20",
    "unique-string": "^2.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.4.1",
    "@commitlint/config-conventional": "^19.4.1",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/cookie-parser": "^1.4.8",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.2",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.19.41",
    "@types/qrcode": "^1.5.6",
    "@types/socket.io": "^3.0.2",
    "@types/supertest": "^6.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^8.42.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "is-ci": "^4.1.0",
    "jest": "^29.5.0",
    "lint-staged": "^15.2.10",
    "prettier": "^3.0.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.3"
  },
  "jest": {
  "rootDir": ".",
  "roots": ["<rootDir>/test"],
  "moduleFileExtensions": ["js", "json", "ts"],
  "testRegex": "\\.(spec|e2e-spec)\\.ts$",
  "transform": { "^.+\\.(t|j)s$": "ts-jest" },
  "testEnvironment": "node",
  "collectCoverageFrom": ["src/**/*.(t|j)s"],
  "coverageDirectory": "<rootDir>/coverage",
  "moduleNameMapper": {
    "^@modules/(.*)$": "<rootDir>/src/modules/$1",
    "^@adapters/(.*)$": "<rootDir>/src/adapters/$1",
    "^@broker/(.*)$": "<rootDir>/src/broker/$1",
    "^@shared/(.*)$": "<rootDir>/src/shared/$1",
    "^@config/(.*)$": "<rootDir>/src/configs/$1",
    "^src/(.*)$": "<rootDir>/src/$1"
  }
},
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
